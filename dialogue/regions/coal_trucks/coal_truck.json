        "61b5cd80-3447-44f0-a0ee-c7d06ca1e4ee": {
          "id": "61b5cd80-3447-44f0-a0ee-c7d06ca1e4ee",
          "type": "note",
          "selected": false,
          "x": 587.2307705699311,
          "y": 141.23076842900565,
          "ports": [],
          "title": "Note",
          "color": "#19e0e7e6",
          "portsInOrder": [],
          "portsOutOrder": [],
          "text": "removes all coal from players inventory and adds it to the coal truck\nin chat \"You put the coal the truck.\""
        },
        "ba7ce0a1-2917-4874-96e1-bf9eb2ac09e2": {
          "id": "ba7ce0a1-2917-4874-96e1-bf9eb2ac09e2",
          "type": "note",
          "selected": false,
          "x": 144.15384541275657,
          "y": 175.38461474320457,
          "ports": [],
          "title": "Note",
          "color": "#19e0e7e6",
          "portsInOrder": [],
          "portsOutOrder": [],
          "text": "all coal trucks share a single inventory,\nmuch like how tool leprechauns work."
        },
        "89530fb5-d6e1-47e6-a658-63a89b3f639b": {
          "id": "89530fb5-d6e1-47e6-a658-63a89b3f639b",
          "type": "note",
          "selected": false,
          "x": 595.5384629166281,
          "y": -35.076924706453326,
          "ports": [],
          "title": "Note",
          "color": "#19e0e7e6",
          "portsInOrder": [],
          "portsOutOrder": [],
          "text": "tells the player how much coal is currently in the coal truck\nin chat \"The truck contains <x> piece(s) of coal.\"\nno coal \"there is nothing in this coal truck.\""
        },
        "8c64e08a-8e54-4b4f-b266-d85d6191ab40": {
          "id": "8c64e08a-8e54-4b4f-b266-d85d6191ab40",
          "type": "note",
          "selected": false,
          "x": 436.8906718917254,
          "y": -375.0733012514122,
          "ports": [],
          "title": "Note",
          "color": "#19e0e7e6",
          "portsInOrder": [],
          "portsOutOrder": [],
          "text": "Gives the player all the coal they can carry, if they dont have space,\nthey cant take anymore.\nin chat \"You remove the coal from the truck.\"\nin chat if no inventory space \"You do not have enough inventory space!\"\nif has inventory space but not enough to hold all the coal in the truck \"You remove some of the coal from the truck.\""
        },
        "201ed457-e709-419c-96a0-cf4c39503662": {
          "id": "201ed457-e709-419c-96a0-cf4c39503662",
          "type": "note",
          "selected": false,
          "x": 269.69230754062266,
          "y": -72.92307873029532,
          "ports": [],
          "title": "Note",
          "color": "#19e0e7e6",
          "portsInOrder": [],
          "portsOutOrder": [],
          "text": "120 pieces can be stored\nin the coal trucks."
        },
        "a1142f94-dc4c-4112-b837-569b973cf988": {
          "id": "a1142f94-dc4c-4112-b837-569b973cf988",
          "type": "note",
          "selected": false,
          "x": 151.55992806641396,
          "y": 356.9946336385252,
          "ports": [],
          "title": "Note",
          "color": "#19e0e7e6",
          "portsInOrder": [],
          "portsOutOrder": [],
          "text": "\"An exploit currently exists in which a player can transport 27 \nadditional coal if the trucks are filled up to one less than full, then an\n entire inventory of coal is placed in the cart.\" -Coal truck Wiki"
        },
        "c5f7f64a-fd52-4958-a0dd-0cfd4ffc0c37": {
          "id": "c5f7f64a-fd52-4958-a0dd-0cfd4ffc0c37",
          "type": "note",
          "selected": false,
          "x": 267.91607039624716,
          "y": -162.8676930545497,
          "ports": [],
          "title": "Note",
          "color": "#19e0e7e6",
          "portsInOrder": [],
          "portsOutOrder": [],
          "text": "Does NOT require the completion\nof Dwarf Cannon Quest to use"
        },
